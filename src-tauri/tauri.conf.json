{
  "$schema": "https://raw.githubusercontent.com/nickkuk/nickkuk.github.io/refs/heads/main/tauri-v2-schema.json",
  "productName": "todotext",
  "version": "0.1.0",
  "identifier": "de.todotext.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "todotext.de",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "store": {
      "path": ".todotext.dat"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [],
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "Simple todo.txt task manager",
    "longDescription": "A fast, offline-first task manager using the todo.txt format. Sync with Dropbox & Google Drive."
  }
}
